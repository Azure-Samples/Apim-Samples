<policies>
    <inbound>
        <base />
        <!-- A simple, static rewrite is enough to show permitted egress functionality.
        The policy and APIM are less important than the route table, routes, and Azure Firewall NVA. -->
        <rewrite-uri template="/stations/SEAW1" />
    </inbound>
    <backend>
        <base />
    </backend>
    <outbound>
        <base />
    </outbound>
    <on-error>
        <base />
    </on-error>
</policies>

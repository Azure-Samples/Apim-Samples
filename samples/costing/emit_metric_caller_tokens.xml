<!--
    AI Gateway Token Tracking Policy

    Handles inbound caller identification and context propagation when
    APIM is used as an AI Gateway in front of Azure OpenAI or compatible
    LLM backends. Token consumption is tracked via the APIM diagnostic
    setting ('Logs related to generative AI gateway') which writes
    per-request data to ApiManagementGatewayLlmLog; no response
    buffering required at the policy level.

    The built-in Azure OpenAI metrics (PTU utilization, token counts) are
    reported at the model/deployment level and do NOT break down by client.
    This policy fills that gap by propagating caller identity headers and
    enabling accurate streaming token counts, while the diagnostic log
    provides per-request token breakdowns.

    Metrics emitted:
      - 'caller-requests' with dimensions CallerId, API, Operation

    Caller identification:
      - Uses the 'Extract-CallerId' policy fragment to read appid / azp
        from the JWT Authorization header
      - Falls back to the APIM subscription ID if no JWT is present

    Context propagation:
      - Injects x-business-unit header (= callerId) so downstream
        services (Foundry, AOAI) can correlate with APIM without client help.
      - Injects x-ms-client-request-id header (= APIM request ID) for
        end-to-end correlation in Application Insights.

    Streaming support:
      When force_stream_include_usage is enabled in the notebook, the
      inbound section automatically injects stream_options.include_usage
      into streaming requests that lack it. This ensures the backend
      includes token counts in the final SSE chunk, which the APIM
      gateway infrastructure reads on the fly without buffering.

    Token tracking via diagnostic logs:
      This policy does NOT parse the response body or emit token metrics
      at the policy level. Instead, token counts are captured by the APIM
      diagnostic setting 'Logs related to generative AI gateway', which
      writes per-request data to the ApiManagementGatewayLlmLog table in
      Log Analytics. This avoids any response buffering overhead.

      To correlate token counts with business units, join
      ApiManagementGatewayLlmLog with ApiManagementGatewayLogs on
      CorrelationId and use the ApimSubscriptionId field as the BU key.
      See bu-token-usage.kql for a ready-to-use query.

    USAGE:
      Point the API's serviceUrl to your Azure OpenAI deployment
      (e.g. https://YOUR-AOAI.openai.azure.com) and enable the
      'Logs related to generative AI gateway' diagnostic setting.
      Token counts are written to ApiManagementGatewayLlmLog
      automatically for every request.
-->
<policies>
    <inbound>
        <base />
        <!-- [STREAM-USAGE-ENFORCEMENT-BEGIN] -->
        <!--
            Ensure streaming AI requests include stream_options.include_usage = true.
            Without this, SSE responses omit the usage object and the gateway
            infrastructure cannot extract exact token counts for the
            ApiManagementGatewayLlmLog diagnostic. Controlled by
            force_stream_include_usage in the notebook; when False, this block
            is stripped before deployment.
        -->
        <choose>
            <when condition="@(context.Request.Body != null && context.Request.Headers.GetValueOrDefault("Content-Type", "").Contains("json"))">
                <set-body>@{
                    try {
                        var body = context.Request.Body.As<Newtonsoft.Json.Linq.JObject>(preserveContent: true);
                        if (body["stream"]?.Value<bool>() == true) {
                            var streamOptions = body["stream_options"] as Newtonsoft.Json.Linq.JObject;
                            if (streamOptions == null) {
                                body["stream_options"] = new Newtonsoft.Json.Linq.JObject(
                                    new Newtonsoft.Json.Linq.JProperty("include_usage", true)
                                );
                            } else if (streamOptions["include_usage"]?.Value<bool>() != true) {
                                streamOptions["include_usage"] = true;
                            }
                        }
                        return body.ToString();
                    } catch {
                        return context.Request.Body.As<string>(preserveContent: true);
                    }
                }</set-body>
            </when>
        </choose>
        <!-- [STREAM-USAGE-ENFORCEMENT-END] -->
        <!-- Extract caller identity (appid/azp from JWT, or APIM subscription ID) -->
        <include-fragment fragment-id="Extract-CallerId" />
        <!-- Count each request per caller (same as emit_metric_caller_id.xml) -->
        <emit-metric name="caller-requests" value="1" namespace="apim-costing">
            <dimension name="CallerId" value="@((string)context.Variables["callerId"])" />
            <dimension name="API" value="@(context.Api.Name)" />
            <dimension name="Operation" value="@(context.Operation.Name)" />
        </emit-metric>
        <!-- Propagate caller identity to downstream services (Foundry / AOAI) -->
        <set-header name="x-business-unit" exists-action="override">
            <value>@((string)context.Variables["callerId"])</value>
        </set-header>
        <!-- Propagate APIM request ID for end-to-end correlation in App Insights -->
        <set-header name="x-ms-client-request-id" exists-action="skip">
            <value>@(context.RequestId.ToString())</value>
        </set-header>
    </inbound>
    <backend>
        <base />
    </backend>
    <outbound>
        <base />
    </outbound>
    <on-error>
        <base />
    </on-error>
</policies>
